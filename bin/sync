#!/usr/bin/env python3
"""Sync methodology starter-kit files into a project.

Contract: methodology v2.2 plan §4D.
"""
import argparse
import base64
import hashlib
import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _manifest import DISTRIBUTION, TRACKED, SEED  # noqa: E402  (bin/ on sys.path)

REPO = "KJ5HST/methodology"
# Only TRACKED dests are gitignored (ignore mode) and checked for accidental git
# tracking. SEED files become adopter-owned after first creation and are meant to
# be committed, so they are deliberately excluded from both.
TRACKED_DESTS = tuple(dest for _src, dest, disp in DISTRIBUTION if disp == TRACKED)
IGNORE_ENTRIES = tuple(f"/{dest}" for dest in TRACKED_DESTS)


def script_methodology_root() -> Path:
    # This script lives at <methodology>/bin/sync.
    return Path(__file__).resolve().parent.parent


def detect_mode(project: Path) -> str:
    gitignore = project / ".gitignore"
    if not gitignore.exists():
        return "commit"
    existing = set(line.strip() for line in gitignore.read_text().splitlines())
    if any(entry in existing for entry in IGNORE_ENTRIES):
        return "ignore"
    return "commit"


def detect_source(methodology_root: Path) -> str:
    if (methodology_root / "starter-kit").is_dir():
        return "local"
    return "github"


def blob_sha(content: bytes) -> str:
    header = f"blob {len(content)}\0".encode()
    return hashlib.sha1(header + content).hexdigest()


def read_local(methodology_root: Path, src: str) -> bytes:
    return (methodology_root / src).read_bytes()


def local_history_blobs(methodology_root: Path, src: str) -> set:
    """Set of blob SHAs this file has had across methodology git history."""
    path = src
    try:
        log = subprocess.run(
            ["git", "-C", str(methodology_root), "log", "--format=%H", "--", path],
            capture_output=True, text=True, check=True,
        ).stdout.strip().splitlines()
    except (FileNotFoundError, subprocess.CalledProcessError):
        return set()
    blobs = set()
    for commit in log:
        try:
            tree = subprocess.run(
                ["git", "-C", str(methodology_root), "ls-tree", commit, "--", path],
                capture_output=True, text=True, check=True,
            ).stdout.strip()
        except subprocess.CalledProcessError:
            continue
        parts = tree.split()
        if len(parts) >= 3 and parts[1] == "blob":
            blobs.add(parts[2])
    return blobs


def read_github(src: str) -> bytes:
    try:
        result = subprocess.run(
            ["gh", "api", f"repos/{REPO}/contents/{src}"],
            capture_output=True, text=True, check=True,
        )
    except FileNotFoundError:
        sys.exit("error: gh CLI not found; install GitHub CLI or use --source=local")
    except subprocess.CalledProcessError as e:
        sys.exit(f"error: gh api failed for {src}: {e.stderr.strip() or e.stdout.strip()}\n"
                 f"hint: run `gh auth login` or use --source=local")
    payload = json.loads(result.stdout)
    return base64.b64decode(payload["content"])


def methodology_version(methodology_root: Path, source: str) -> str:
    if source == "local":
        try:
            out = subprocess.run(
                ["git", "-C", str(methodology_root), "describe", "--tags", "--always"],
                capture_output=True, text=True, check=True,
            ).stdout.strip()
            return out or "local"
        except (FileNotFoundError, subprocess.CalledProcessError):
            return "local"
    # github
    try:
        out = subprocess.run(
            ["gh", "api", f"repos/{REPO}/commits/main", "--jq", ".sha"],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
        return f"github:{out[:7]}" if out else "github:main"
    except (FileNotFoundError, subprocess.CalledProcessError):
        return "github:main"


def ensure_gitignore_entries(project: Path, dry_run: bool) -> list:
    gitignore = project / ".gitignore"
    current = gitignore.read_text().splitlines() if gitignore.exists() else []
    existing = set(line.strip() for line in current)
    to_add = [e for e in IGNORE_ENTRIES if e not in existing]
    if not to_add:
        return []
    if dry_run:
        return to_add
    with gitignore.open("a") as f:
        if current and current[-1].strip() != "":
            f.write("\n")
        f.write("# Methodology files (synced from ../methodology/; run ../methodology/bin/sync .)\n")
        for entry in to_add:
            f.write(entry + "\n")
    return to_add


def currently_tracked(project: Path) -> list:
    try:
        out = subprocess.run(
            ["git", "-C", str(project), "ls-files", "--error-unmatch", "--", *TRACKED_DESTS],
            capture_output=True, text=True, check=False,
        )
    except FileNotFoundError:
        return []
    return [line for line in out.stdout.splitlines() if line]


def classify_target(target: Path, canonical_content: bytes, history_blobs: set) -> str:
    """Return 'missing', 'current', 'upgradable', or 'modified'."""
    if not target.exists():
        return "missing"
    current = target.read_bytes()
    if current == canonical_content:
        return "current"
    if blob_sha(current) in history_blobs:
        return "upgradable"
    return "modified"


def sync_file(project: Path, dest: str, content: bytes, dry_run: bool) -> str:
    target = project / dest
    if target.exists() and target.read_bytes() == content:
        return "unchanged"
    action = "would write" if dry_run else ("updated" if target.exists() else "created")
    if not dry_run:
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_bytes(content)
        if dest.endswith(".py"):
            mode = target.stat().st_mode
            target.chmod(mode | 0o111)
    return action


def seed_file(project: Path, dest: str, content: bytes, dry_run: bool) -> str:
    """SEED disposition: write only when the dest is absent; never overwrite an
    existing file, even with --force (Decision 2a; SEED-ONCE-clobber dragon)."""
    target = project / dest
    if target.exists():
        return "present (seed; left as-is)"
    action = "would create" if dry_run else "created"
    if not dry_run:
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_bytes(content)
        if dest.endswith(".py"):
            mode = target.stat().st_mode
            target.chmod(mode | 0o111)
    return action


def main() -> int:
    p = argparse.ArgumentParser(description="Sync methodology starter-kit files into a project.")
    p.add_argument("project_path", help="Target project directory")
    p.add_argument("--mode", choices=("commit", "ignore"), help="commit (default) or ignore")
    p.add_argument("--source", choices=("local", "github"), help="local (default if sibling methodology/ exists) or github")
    p.add_argument("--dry-run", action="store_true", help="Print intent without writing")
    p.add_argument("--force", action="store_true",
                   help="Overwrite files that show local modifications (not matching canonical or any historical version)")
    args = p.parse_args()

    project = Path(args.project_path).resolve()
    if not project.is_dir():
        sys.exit(f"error: {project} is not a directory")

    methodology_root = script_methodology_root()
    source = args.source or detect_source(methodology_root)
    if source == "local" and not (methodology_root / "starter-kit").is_dir():
        sys.exit(f"error: --source=local but no starter-kit/ at {methodology_root}")

    mode = args.mode or detect_mode(project)
    version = methodology_version(methodology_root, source)

    print(f"sync: {project}")
    print(f"  source:  {source}" + (f" ({methodology_root})" if source == "local" else ""))
    print(f"  mode:    {mode}")
    print(f"  version: {version}")
    if args.dry_run:
        print("  (dry-run: no changes will be written)")

    entries = []  # (src, dest, disposition, content, classification)
    for src, dest, disp in DISTRIBUTION:
        content = read_local(methodology_root, src) if source == "local" else read_github(src)
        target = project / dest
        if disp == SEED:
            # SEED files are adopter-owned; classification is only present/missing.
            cls = "present" if target.exists() else "missing"
        else:  # TRACKED
            history = local_history_blobs(methodology_root, src) if source == "local" else set()
            cls = classify_target(target, content, history)
        entries.append((src, dest, disp, content, cls))

    # Only TRACKED files can block: SEED files are never overwritten, so they
    # cannot be "modified" in the drift sense.
    blocked = [(src, dest) for src, dest, disp, _content, cls in entries
               if disp == TRACKED and cls == "modified"]
    if blocked and not args.force:
        print("")
        print("  ERROR: the following files have local modifications that don't match")
        print("  any canonical or historical version and would be overwritten:")
        for _src, dest in blocked:
            print(f"    {dest}")
        print("")
        print("  The recommended pattern (see plan §3.2) is to move per-project")
        print("  customizations into CLAUDE.md's 'Project-Specific Methodology")
        print("  Adaptations' section, keeping synced files byte-identical to canonical.")
        print("")
        print("  To proceed anyway and overwrite local changes, pass --force.")
        print("  To inspect the drift first:")
        for src, dest in blocked:
            if source == "local":
                print(f"    diff {project / dest} {methodology_root / src}")
        return 2

    file_results = []
    for src, dest, disp, content, _cls in entries:
        if disp == SEED:
            result = seed_file(project, dest, content, args.dry_run)
        else:
            result = sync_file(project, dest, content, args.dry_run)
        file_results.append((dest, result))

    print("  files:")
    for dest, result in file_results:
        print(f"    {dest}: {result}")

    if mode == "ignore":
        added = ensure_gitignore_entries(project, args.dry_run)
        if added:
            verb = "would add" if args.dry_run else "added"
            print(f"  .gitignore: {verb} {', '.join(added)}")
        else:
            print("  .gitignore: entries already present")

        if (project / ".git").exists():
            tracked = currently_tracked(project)
            if tracked:
                print("")
                print("  WARNING: the following files are currently tracked by git:")
                for f in tracked:
                    print(f"    {f}")
                print("  Run this to stop tracking them (keeps local copies):")
                print(f"    git -C {project} rm --cached {' '.join(tracked)}")
                print("  Then commit the removal. This script does not run it for you.")

    return 0


if __name__ == "__main__":
    sys.exit(main())
